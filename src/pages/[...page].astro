---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import { profileConfig } from "../config";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../utils/content-utils";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { getPostUrlBySlug, url } from "../utils/url-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
const totalPosts = page.total;
const categories = await getCategoryList();
const tags = await getTagList();
const latestPosts = page.data.slice(0, 3);
const topCategories = [...categories].sort((a, b) => b.count - a.count).slice(0, 4);
const topTags = [...tags].sort((a, b) => b.count - a.count).slice(0, 8);
---

<MainGridLayout>
    {page.currentPage === 1 && (
        <section class="home-console card-base motion-reveal" style="--reveal-delay: 90ms" aria-label="Knowledge base console">
            <div class="term" aria-label="terminal">
                <div class="term-bar">
                    <span class="term-dots"><i></i><i></i><i></i></span>
                    <span class="term-titlebar">{profileConfig.name.toLowerCase()}@algo — ~/knowledge-base — zsh</span>
                    <span class="term-live"><i></i>ONLINE</span>
                </div>
                <div class="term-body">
                    <p class="term-line"><span class="term-prompt">➜</span><span class="term-path">~</span><span class="term-cmd c1">whoami</span></p>
                    <p class="term-out o1">{profileConfig.name} · C++ 算法竞赛 &amp; 学习记录</p>

                    <p class="term-line"><span class="term-prompt">➜</span><span class="term-path">~</span><span class="term-cmd c2">stats --all</span></p>
                    <p class="term-out o2 term-stats">
                        <span class="term-stat"><b>{totalPosts}</b> notes</span>
                        <span class="term-stat"><b>{categories.length}</b> categories</span>
                        <span class="term-stat"><b>{tags.length}</b> tags</span>
                        <span class="term-stat"><b>{page.lastPage}</b> pages</span>
                    </p>

                    <p class="term-line"><span class="term-prompt">➜</span><span class="term-path">~</span><span class="term-cmd c3">open</span><span class="term-caret">▍</span></p>
                    <div class="home-actions term-actions o3">
                        <a href={url("/catalog/")} class="home-action primary">
                            <Icon name="material-symbols:account-tree-outline-rounded" />
                            知识目录
                        </a>
                        <a href={url("/archive/")} class="home-action">
                            <Icon name="material-symbols:event-note-outline-rounded" />
                            时间归档
                        </a>
                        <a href={url("/about/")} class="home-action">
                            <Icon name="material-symbols:person-outline-rounded" />
                            关于我
                        </a>
                    </div>
                </div>
            </div>

            <div class="home-console-lower">
                <div class="home-panel latest-panel">
                    <div class="home-panel-title">
                        <Icon name="material-symbols:bolt-outline-rounded" />
                        最近更新
                    </div>
                    <div class="latest-list">
                        {latestPosts.map((post) => (
                            <a href={getPostUrlBySlug(post.slug)} class="latest-item">
                                <span>{formatDateToYYYYMMDD(post.data.published)}</span>
                                <strong>{post.data.title}</strong>
                            </a>
                        ))}
                    </div>
                </div>

                <div class="home-panel taxonomy-panel">
                    <div class="home-panel-title">
                        <Icon name="material-symbols:category-outline-rounded" />
                        高频分类
                    </div>
                    <div class="category-meter-list">
                        {topCategories.map((category) => (
                            <a href={category.url} class="category-meter">
                                <span>{category.name}</span>
                                <strong>{category.count}</strong>
                            </a>
                        ))}
                    </div>
                    <div class="tag-strip" aria-label="Top tags">
                        {topTags.map((tag) => (
                            <a href={url(`/archive/?tag=${encodeURIComponent(tag.name.trim())}`)}>
                                #{tag.name}
                            </a>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    )}
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>

<style>
    .home-console {
        position: relative;
        isolation: isolate;
        margin-bottom: 1rem;
        padding: 1.2rem;
        overflow: hidden;
    }

    .home-console::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background:
            linear-gradient(90deg, color-mix(in oklch, var(--primary) 64%, white) 0 0.3rem, transparent 0.3rem),
            radial-gradient(circle at 12% 0%, color-mix(in oklch, var(--primary) 24%, transparent), transparent 38%),
            radial-gradient(circle at 88% 0%, color-mix(in oklch, var(--accent-2) 18%, transparent), transparent 34%),
            linear-gradient(135deg, color-mix(in oklch, var(--primary) 8%, transparent), transparent 48%);
        pointer-events: none;
    }

    /* ---------- Terminal hero (always dark, like a code block) ---------- */
    .term {
        position: relative;
        z-index: 1;
        border-radius: 0.9rem;
        overflow: hidden;
        border: 1px solid color-mix(in oklch, var(--primary) 34%, transparent);
        background:
            radial-gradient(circle at 88% -20%, color-mix(in oklch, var(--accent-2) 24%, transparent), transparent 46%),
            linear-gradient(180deg, oklch(0.2 0.022 var(--hue)), oklch(0.15 0.018 var(--hue)));
        box-shadow:
            0 26px 64px rgba(0, 0, 0, 0.42),
            0 0 0 1px color-mix(in oklch, var(--primary) 18%, transparent),
            0 0 48px color-mix(in oklch, var(--primary) 20%, transparent);
        font-family: var(--font-display);
    }

    .term-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.85rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02));
        border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    }

    .term-dots {
        display: inline-flex;
        gap: 0.4rem;
    }

    .term-dots i {
        width: 0.72rem;
        height: 0.72rem;
        border-radius: 999px;
        background: #ff5f57;
    }

    .term-dots i:nth-child(2) { background: #febc2e; }
    .term-dots i:nth-child(3) { background: #28c840; }

    .term-titlebar {
        flex: 1;
        min-width: 0;
        text-align: center;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.76rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .term-live {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: #35d07f;
        font-size: 0.66rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .term-live i {
        width: 0.42rem;
        height: 0.42rem;
        border-radius: 999px;
        background: #35d07f;
        box-shadow: 0 0 10px #35d07f;
        animation: term-pulse 2s ease-in-out infinite;
    }

    .term-body {
        padding: 1.15rem 1.25rem 1.3rem;
        font-size: 0.95rem;
        line-height: 1.95;
    }

    .term-line {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.92);
    }

    .term-prompt { color: #35d07f; font-weight: 700; }
    .term-path { color: var(--primary); }

    .term-cmd {
        display: inline-block;
        overflow: hidden;
        white-space: nowrap;
        vertical-align: bottom;
        width: 0;
        color: #fff;
    }

    .term-cmd.c1 { animation: term-type6 0.5s steps(6) 0.25s forwards; }
    .term-cmd.c2 { animation: term-type11 0.75s steps(11) 1.2s forwards; }
    .term-cmd.c3 { animation: term-type4 0.35s steps(4) 2.4s forwards; }

    .term-caret {
        color: var(--primary);
        text-shadow: 0 0 12px var(--primary);
        animation: term-blink 1.1s steps(1, end) infinite;
    }

    .term-out {
        color: rgba(255, 255, 255, 0.66);
        padding-left: 1.65rem;
        opacity: 0;
        animation: term-rise 0.45s ease forwards;
    }

    .term-out.o1 { animation-delay: 0.85s; }
    .term-out.o2 { animation-delay: 2.05s; }

    .term-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1.5rem;
    }

    .term-stat b {
        color: var(--primary);
        font-size: 1.05rem;
        text-shadow: 0 0 16px color-mix(in oklch, var(--primary) 55%, transparent);
    }

    .term-actions {
        margin-top: 1.1rem;
        padding-left: 1.65rem;
        opacity: 0;
        animation: term-rise 0.45s ease 2.75s forwards;
    }

    @keyframes term-type6 { to { width: 6ch; } }
    @keyframes term-type11 { to { width: 11ch; } }
    @keyframes term-type4 { to { width: 4ch; } }
    @keyframes term-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
    @keyframes term-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
    @keyframes term-rise {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: none; }
    }

    @media (prefers-reduced-motion: reduce) {
        .term-cmd { width: auto !important; animation: none !important; }
        .term-out,
        .term-actions { opacity: 1 !important; animation: none !important; }
        .term-caret,
        .term-live i { animation: none !important; }
    }

    .home-console-lower {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(17rem, 24rem);
        gap: 1rem;
        margin-top: 1rem;
    }

    .home-panel {
        border: 1px solid color-mix(in oklch, var(--primary) 13%, transparent);
        border-radius: 0.95rem;
        background: color-mix(in oklch, var(--card-bg) 72%, transparent);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.34);
        padding: 1rem;
    }

    .home-panel-title {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--primary);
        font-size: 0.82rem;
        font-weight: 950;
        letter-spacing: 0;
        margin-bottom: 0.75rem;
    }

    .latest-list,
    .category-meter-list {
        display: grid;
        gap: 0.55rem;
    }

    .latest-item,
    .category-meter {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 0.75rem;
        border-radius: 0.75rem;
        padding: 0.7rem 0.75rem;
        color: rgba(0, 0, 0, 0.72);
        background: color-mix(in oklch, var(--primary) 4%, transparent);
        transition:
            transform 180ms ease,
            background-color 180ms ease,
            color 180ms ease;
    }

    .latest-item:hover,
    .category-meter:hover {
        color: var(--primary);
        background: color-mix(in oklch, var(--primary) 9%, transparent);
        transform: translateX(0.25rem);
    }

    :global(.dark) .latest-item,
    :global(.dark) .category-meter {
        color: rgba(255, 255, 255, 0.72);
    }

    .latest-item span {
        color: rgba(0, 0, 0, 0.42);
        font-size: 0.76rem;
        font-weight: 900;
        font-variant-numeric: tabular-nums;
    }

    :global(.dark) .latest-item span {
        color: rgba(255, 255, 255, 0.42);
    }

    .latest-item strong,
    .category-meter span {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 900;
    }

    .category-meter {
        grid-template-columns: minmax(0, 1fr) auto;
    }

    .category-meter strong {
        display: inline-grid;
        min-width: 1.65rem;
        height: 1.65rem;
        place-items: center;
        border-radius: 999px;
        background: var(--primary);
        color: var(--card-bg);
        font-size: 0.78rem;
        line-height: 1;
    }

    .tag-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0.8rem;
    }

    .tag-strip a {
        border-radius: 999px;
        background: color-mix(in oklch, var(--primary) 7%, transparent);
        padding: 0.32rem 0.55rem;
        color: var(--primary);
        font-size: 0.76rem;
        font-weight: 900;
    }

    @media (max-width: 768px) {
        .home-console-lower {
            grid-template-columns: 1fr;
        }

        .home-console {
            padding: 1.15rem;
        }

        .term-stats {
            gap: 0.35rem 1rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .home-action,
        .latest-item,
        .category-meter {
            transition: none;
        }

        .home-action.primary,
        .home-action:hover,
        .latest-item:hover,
        .category-meter:hover {
            transform: none;
        }
    }
</style>
