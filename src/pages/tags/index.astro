---
import TagCloud from "@components/TagCloud.astro";
import TagGraph from "@components/TagGraph.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getFamilyGroups,
	getTagGraph,
	getTagsDetailed,
} from "@utils/tag-utils";
import { Icon } from "astro-icon/components";

const tags = await getTagsDetailed();
const groups = await getFamilyGroups();
const graph = await getTagGraph();

const totalTags = tags.length;
const totalFamilies = groups.length;
const topTag = tags[0];
---

<MainGridLayout title="标签中心">
	<div class="tag-hub">
		<!-- header -->
		<section class="hub-head card-base">
			<div class="hub-kicker">
				<Icon name="material-symbols:tag-rounded" />
				~/tags
			</div>
			<h1>标签中心</h1>
			<p>把零散的题解标签，整理成一张可浏览的算法技能地图。</p>
			<div class="hub-stats">
				<div><strong>{totalTags}</strong><span>Tags</span></div>
				<div><strong>{totalFamilies}</strong><span>Families</span></div>
				<div><strong>{graph.edges.length}</strong><span>Links</span></div>
				{topTag && <div><strong>{topTag.count}</strong><span>#{topTag.name}</span></div>}
			</div>
		</section>

		<!-- weighted cloud -->
		<section class="hub-block card-base">
			<div class="hub-block-title">
				<Icon name="material-symbols:grid-view-rounded" />
				标签云 · 越大越常用
			</div>
			<TagCloud tags={tags} />
		</section>

		<!-- co-occurrence graph -->
		<section class="hub-block card-base">
			<div class="hub-block-title">
				<Icon name="material-symbols:schema-rounded" />
				共现关系图 · 悬停查看关联
			</div>
			<p class="hub-block-hint">连线表示两个技术点出现在同一篇题解里，越亮越常一起用。（已隐藏无处不在的语言标签）</p>
			<TagGraph data={graph} />
		</section>

		<!-- skill tree -->
		<section class="hub-block card-base">
			<div class="hub-block-title">
				<Icon name="material-symbols:account-tree-outline-rounded" />
				技能树 · 按技术族分组
			</div>
			<div class="family-list">
				{groups.map((g) => (
					<div class="family" style={`--fam-hue:${g.family.hue}`}>
						<div class="family-head">
							<span class="family-icon"><Icon name={g.family.icon} /></span>
							<span class="family-name">{g.family.name}</span>
							<span class="family-meta">{g.tagCount} 标签 · {g.postCount} 题</span>
						</div>
						{g.family.blurb && <div class="family-blurb">{g.family.blurb}</div>}
						<TagCloud tags={g.tags} class="family-cloud" />
					</div>
				))}
			</div>
		</section>
	</div>
</MainGridLayout>

<style>
	.tag-hub {
		display: grid;
		gap: 1rem;
		color: rgba(0, 0, 0, 0.82);
	}

	:global(.dark) .tag-hub {
		color: rgba(255, 255, 255, 0.84);
	}

	.hub-head,
	.hub-block {
		position: relative;
		padding: 1.3rem 1.35rem;
		overflow: hidden;
	}

	.hub-head::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 0;
		background:
			linear-gradient(90deg, color-mix(in oklch, var(--primary) 60%, white) 0 0.3rem, transparent 0.3rem),
			radial-gradient(circle at 90% 0%, color-mix(in oklch, var(--accent-2, oklch(0.7 0.15 300)) 18%, transparent), transparent 40%);
		pointer-events: none;
	}

	.hub-head > * {
		position: relative;
		z-index: 1;
	}

	.hub-kicker,
	.hub-block-title {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--primary);
		font-family: var(--font-display, monospace);
		font-weight: 800;
		letter-spacing: -0.01em;
	}

	.hub-kicker {
		border: 1px solid color-mix(in oklch, var(--primary) 22%, transparent);
		border-radius: 999px;
		background: color-mix(in oklch, var(--primary) 8%, transparent);
		padding: 0.3rem 0.65rem;
		font-size: 0.78rem;
	}

	.hub-head h1 {
		margin-top: 0.7rem;
		font-family: var(--font-display, monospace);
		font-size: clamp(1.9rem, 4vw, 3rem);
		font-weight: 900;
		line-height: 1.05;
		color: inherit;
	}

	.hub-head p {
		margin-top: 0.5rem;
		color: color-mix(in oklch, currentColor 55%, transparent);
		max-width: 40rem;
	}

	.hub-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.1rem;
	}

	.hub-stats div {
		border: 1px solid color-mix(in oklch, var(--primary) 16%, transparent);
		border-radius: 0.8rem;
		background: color-mix(in oklch, var(--card-bg) 70%, transparent);
		padding: 0.6rem 0.9rem;
		min-width: 5.2rem;
	}

	.hub-stats strong {
		display: block;
		font-family: var(--font-display, monospace);
		font-size: 1.5rem;
		font-weight: 900;
		color: var(--primary);
		text-shadow: 0 0 16px color-mix(in oklch, var(--primary) 40%, transparent);
		font-variant-numeric: tabular-nums;
	}

	.hub-stats span {
		font-size: 0.72rem;
		font-weight: 700;
		color: color-mix(in oklch, currentColor 45%, transparent);
	}

	.hub-block-title {
		font-size: 0.95rem;
		margin-bottom: 0.9rem;
	}

	.hub-block-hint {
		margin: -0.4rem 0 0.9rem;
		font-size: 0.82rem;
		color: color-mix(in oklch, currentColor 48%, transparent);
	}

	.family-list {
		display: grid;
		gap: 0.85rem;
	}

	.family {
		border: 1px solid color-mix(in oklch, oklch(0.7 0.16 var(--fam-hue)) 24%, transparent);
		border-left-width: 3px;
		border-radius: 0.85rem;
		background: color-mix(in oklch, oklch(0.7 0.16 var(--fam-hue)) 5%, transparent);
		padding: 0.9rem 1rem;
	}

	.family-head {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 0.4rem;
	}

	.family-icon {
		display: grid;
		place-items: center;
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 0.5rem;
		background: color-mix(in oklch, oklch(0.7 0.16 var(--fam-hue)) 18%, transparent);
		color: oklch(0.62 0.16 var(--fam-hue));
		font-size: 1.1rem;
	}

	:global(.dark) .family-icon {
		color: oklch(0.78 0.16 var(--fam-hue));
	}

	.family-name {
		font-family: var(--font-display, monospace);
		font-weight: 800;
		font-size: 1.05rem;
	}

	.family-meta {
		margin-left: auto;
		font-size: 0.76rem;
		font-family: var(--font-display, monospace);
		color: color-mix(in oklch, currentColor 45%, transparent);
	}

	.family-blurb {
		margin-bottom: 0.7rem;
		font-size: 0.82rem;
		color: color-mix(in oklch, currentColor 52%, transparent);
	}
</style>
