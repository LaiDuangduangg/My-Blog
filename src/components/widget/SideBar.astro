---
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import { url } from "../../utils/url-utils";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const className = Astro.props.class;
---
<div id="sidebar" class:list={[className, "w-full motion-reveal"]} style="--reveal-delay: 80ms">
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile></Profile>
        <div class="side-control card-base">
            <div class="side-control-title">
                <Icon name="material-symbols:tune-rounded" />
                控制台
            </div>
            <div class="side-control-grid">
                <a href={url("/catalog/")}>
                    <Icon name="material-symbols:account-tree-outline-rounded" />
                    目录
                </a>
                <a href={url("/archive/")}>
                    <Icon name="material-symbols:event-note-outline-rounded" />
                    归档
                </a>
                <a href={url("/about/")}>
                    <Icon name="material-symbols:person-outline-rounded" />
                    关于
                </a>
                <a href={url("/rss.xml")} target="_blank">
                    <Icon name="material-symbols:rss-feed-rounded" />
                    RSS
                </a>
            </div>
        </div>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
        <Categories class="onload-animation motion-reveal" style="animation-delay: 150ms; --reveal-delay: 180ms"></Categories>
    </div>
</div>

<style>
    .side-control {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        padding: 1rem;
    }

    .side-control::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background:
            linear-gradient(90deg, color-mix(in oklch, var(--primary) 58%, white) 0 0.22rem, transparent 0.22rem),
            radial-gradient(circle at 18% 0%, color-mix(in oklch, var(--primary) 18%, transparent), transparent 42%);
        pointer-events: none;
    }

    .side-control-title {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0.8rem;
        color: var(--primary);
        font-size: 0.86rem;
        font-weight: 950;
        letter-spacing: 0;
    }

    .side-control-title :global(svg) {
        font-size: 1.15rem;
    }

    .side-control-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.55rem;
    }

    .side-control-grid a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        min-height: 2.55rem;
        border: 1px solid color-mix(in oklch, var(--primary) 10%, transparent);
        border-radius: 0.75rem;
        background: color-mix(in oklch, var(--card-bg) 72%, transparent);
        color: rgba(0, 0, 0, 0.62);
        font-size: 0.86rem;
        font-weight: 900;
        transition:
            transform 180ms ease,
            background-color 180ms ease,
            color 180ms ease,
            box-shadow 180ms ease;
    }

    .side-control-grid a:hover {
        transform: translateY(-2px);
        background: color-mix(in oklch, var(--primary) 10%, transparent);
        color: var(--primary);
        box-shadow: 0 10px 22px color-mix(in oklch, var(--primary) 10%, transparent);
    }

    .side-control-grid :global(svg) {
        font-size: 1.05rem;
    }

    :global(.dark) .side-control-grid a {
        color: rgba(255, 255, 255, 0.66);
    }

    @media (prefers-reduced-motion: reduce) {
        .side-control-grid a {
            transition: none;
        }

        .side-control-grid a:hover {
            transform: none;
        }
    }
</style>
