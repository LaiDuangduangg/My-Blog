---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
---
<div class="profile-card card-base p-3">
    <div class="profile-status" aria-hidden="true">
        <span></span>
        ONLINE
    </div>
    <a aria-label="Go to About Page" href={url('/about/')}
       class="profile-avatar group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
    </div>
</div>

<style>
	.profile-card {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding-top: 2.35rem;
	}

	.profile-status {
		position: absolute;
		top: 0.85rem;
		right: 0.85rem;
		z-index: 3;
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		border: 1px solid color-mix(in oklch, var(--primary) 28%, transparent);
		border-radius: 999px;
		background: color-mix(in oklch, var(--card-bg) 82%, transparent);
		padding: 0.25rem 0.55rem;
		color: color-mix(in oklch, var(--primary) 76%, black);
		font-size: 0.66rem;
		font-weight: 950;
		letter-spacing: 0;
	}

	:global(.dark) .profile-status {
		color: color-mix(in oklch, var(--primary) 78%, white);
	}

	.profile-status span {
		width: 0.43rem;
		height: 0.43rem;
		border-radius: 999px;
		background: var(--primary);
		box-shadow: 0 0 14px color-mix(in oklch, var(--primary) 72%, transparent);
	}

	.profile-card::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			linear-gradient(90deg, color-mix(in oklch, var(--primary) 65%, white) 0 0.24rem, transparent 0.24rem),
			radial-gradient(
				circle at 30% 0%,
				color-mix(in oklch, var(--primary) 28%, transparent),
				transparent 42%
			),
			repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.09) 0 1px, transparent 1px 8px);
		opacity: 0.82;
		transition: opacity 220ms ease;
	}

	.profile-card:hover::before {
		opacity: 1;
	}

	.profile-avatar {
		border: 1px solid color-mix(in oklch, var(--primary) 26%, transparent);
		box-shadow:
			0 0 0 3px color-mix(in oklch, var(--primary) 14%, transparent),
			0 18px 46px rgba(0, 0, 0, 0.14);
		transition:
			transform 220ms ease,
			box-shadow 220ms ease;
	}

	.profile-avatar::before {
		content: "";
		position: absolute;
		inset: -45%;
		z-index: 1;
		pointer-events: none;
		background: conic-gradient(
			from 0deg,
			transparent,
			color-mix(in oklch, var(--primary) 45%, white),
			transparent 28%
		);
		opacity: 0;
		transition: opacity 220ms ease;
	}

	.profile-avatar::after {
		content: "";
		position: absolute;
		inset: 2px;
		z-index: 2;
		pointer-events: none;
		border-radius: 0.65rem;
		border: 1px solid rgba(255, 255, 255, 0.45);
	}

	.profile-avatar:hover {
		transform: translateY(-4px) scale(1.025);
		box-shadow:
			0 0 0 3px color-mix(in oklch, var(--primary) 30%, transparent),
			0 24px 58px rgba(0, 0, 0, 0.2),
			0 0 34px color-mix(in oklch, var(--primary) 18%, transparent);
	}

	.profile-avatar:hover::before {
		opacity: 0.35;
		animation: profile-glow-spin 5.5s linear infinite;
	}

	@keyframes profile-glow-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.profile-card::before,
		.profile-avatar,
		.profile-avatar::before {
			animation: none;
			transition: none;
		}

		.profile-avatar:hover {
			transform: none;
		}
	}
</style>

