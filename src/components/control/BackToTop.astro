---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper hidden lg:block">
    <div id="back-to-top-btn" class="back-to-top-btn hide flex items-center rounded-2xl overflow-hidden transition" onclick="backToTop()">
        <button aria-label="Back to Top" class="btn-card back-to-top-control h-[3.75rem] w-[3.75rem]">
            <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto"></Icon>
        </button>
    </div>
</div>

<style>
.back-to-top-wrapper {
    width: 3.75rem;
    height: 3.75rem;
    position: absolute;
    right: 0;
    top: 0;
    pointer-events: none;
}

.back-to-top-btn {
    color: var(--primary);
    font-size: 2.25rem;
    font-weight: bold;
    border: none;
    position: fixed;
    bottom: 10rem;
    opacity: 1;
    cursor: pointer;
    transform: translateX(5rem);
    pointer-events: auto;
}

.back-to-top-btn i {
    font-size: 1.75rem;
}

.back-to-top-btn.hide {
    transform: translateX(5rem) scale(0.9);
    opacity: 0;
    pointer-events: none;
}

.back-to-top-btn:active {
    transform: translateX(5rem) scale(0.9);
}

.back-to-top-control {
    border: 1px solid color-mix(in oklch, var(--primary) 18%, transparent);
    background: color-mix(in oklch, var(--card-bg) 72%, transparent);
    box-shadow:
        0 16px 38px rgba(0, 0, 0, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.32);
    backdrop-filter: blur(14px) saturate(1.12);
}

.back-to-top-control:hover {
    box-shadow:
        0 18px 46px color-mix(in oklch, var(--primary) 14%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, 0.38);
}

</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}
</script>
