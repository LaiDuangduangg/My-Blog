---
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "../config";
import { url } from "../utils/url-utils";

interface Props {
	totalPosts?: number;
	pageCount?: number;
}

const { totalPosts = 0, pageCount = 0 } = Astro.props;
const heroStyle = `--hero-image: url("${url("/hero-bg.jpg")}");`;
---

<section class="home-hero onload-animation" style={heroStyle}>
	<div class="hero-grid" aria-hidden="true"></div>
	<div class="hero-noise" aria-hidden="true"></div>

	<div class="hero-content">
		<div class="hero-kicker">
			<Icon name="material-symbols:terminal-rounded" />
			<span>Algorithm Workspace</span>
		</div>

		<h1>{siteConfig.title}</h1>
		<p>{siteConfig.subtitle}</p>

		<div class="hero-actions">
			<a class="hero-primary" href={url("/catalog/")}>
				<Icon name="material-symbols:account-tree-outline-rounded" />
				<span>进入知识目录</span>
			</a>
			<button class="hero-secondary" type="button" data-open-command>
				<Icon name="material-symbols:manage-search-rounded" />
				<span>快速检索</span>
				<kbd>Ctrl K</kbd>
			</button>
		</div>

		<div class="hero-signals" aria-label="Site stats">
			<div>
				<strong>{totalPosts}</strong>
				<span>篇笔记</span>
			</div>
			<div>
				<strong>{pageCount}</strong>
				<span>页归档</span>
			</div>
			<div>
				<strong>{profileConfig.name}</strong>
				<span>作者</span>
			</div>
		</div>
	</div>

	<div class="hero-snippets" aria-hidden="true">
		<span style="--x: 4rem; --y: 4rem; --d: 0ms;">while (l &lt;= r)</span>
		<span style="--x: 58%; --y: 5rem; --d: 140ms;">dp[i][j]</span>
		<span style="--x: 72%; --y: 68%; --d: 260ms;">O(log n)</span>
		<span style="--x: 10%; --y: 72%; --d: 420ms;">gcd(a, b)</span>
	</div>
</section>

<script>
function bindHeroCommand() {
	document.querySelectorAll("[data-open-command]").forEach((button) => {
		if (button.hasAttribute("data-command-bound")) return;
		button.setAttribute("data-command-bound", "true");
		button.addEventListener("click", () => {
			document.dispatchEvent(new CustomEvent("open-command-palette"));
		});
	});
}

bindHeroCommand();
document.addEventListener("swup:content:replace", bindHeroCommand);
</script>

<style>
	.home-hero {
		position: relative;
		min-height: min(58vh, 34rem);
		margin-bottom: 1rem;
		overflow: hidden;
		border-radius: var(--radius-large);
		background-image:
			linear-gradient(
				90deg,
				rgba(8, 10, 18, 0.86),
				rgba(8, 10, 18, 0.6) 48%,
				rgba(8, 10, 18, 0.34)
			),
			var(--hero-image);
		background-size: cover;
		background-position: center;
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			0 22px 60px rgba(0, 0, 0, 0.16);
		isolation: isolate;
	}

	.hero-grid {
		position: absolute;
		inset: 0;
		z-index: -1;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
		background-size: 4rem 4rem;
		mask-image: linear-gradient(90deg, black, transparent 76%);
	}

	.hero-noise {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			repeating-linear-gradient(
				0deg,
				rgba(255, 255, 255, 0.045) 0 1px,
				transparent 1px 7px
			);
		opacity: 0.24;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		display: flex;
		min-height: inherit;
		max-width: 44rem;
		flex-direction: column;
		justify-content: center;
		padding: 3rem;
		color: white;
	}

	.hero-kicker {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
		padding: 0.42rem 0.65rem;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.78);
		font-size: 0.82rem;
		font-weight: 700;
		backdrop-filter: blur(14px);
	}

	.hero-kicker :global(svg) {
		font-size: 1.1rem;
		color: color-mix(in oklch, var(--primary) 74%, white);
	}

	.home-hero h1 {
		margin: 0;
		max-width: 12ch;
		font-size: 4.25rem;
		font-weight: 900;
		line-height: 1;
		letter-spacing: 0;
		text-wrap: balance;
		text-shadow: 0 10px 32px rgba(0, 0, 0, 0.36);
	}

	.home-hero p {
		max-width: 34rem;
		margin: 1rem 0 0;
		color: rgba(255, 255, 255, 0.76);
		font-size: 1rem;
		line-height: 1.8;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.6rem;
	}

	.hero-primary,
	.hero-secondary {
		display: inline-flex;
		min-height: 2.9rem;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		border-radius: 0.8rem;
		padding: 0 1rem;
		font-weight: 800;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.hero-primary {
		background: color-mix(in oklch, var(--primary) 82%, white);
		color: rgba(12, 12, 16, 0.92);
	}

	.hero-secondary {
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(14px);
	}

	.hero-primary:hover,
	.hero-secondary:hover {
		transform: translateY(-2px);
	}

	.hero-secondary kbd {
		border-radius: 0.35rem;
		background: rgba(255, 255, 255, 0.12);
		padding: 0.1rem 0.36rem;
		font-size: 0.72rem;
		font-weight: 900;
	}

	.hero-signals {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1.8rem;
		color: rgba(255, 255, 255, 0.72);
	}

	.hero-signals div {
		display: grid;
		gap: 0.2rem;
		min-width: 5.2rem;
		padding-right: 1rem;
		border-right: 1px solid rgba(255, 255, 255, 0.16);
	}

	.hero-signals div:last-child {
		border-right: 0;
	}

	.hero-signals strong {
		color: white;
		font-size: 1.15rem;
		line-height: 1;
	}

	.hero-signals span {
		font-size: 0.78rem;
	}

	.hero-snippets {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.hero-snippets span {
		position: absolute;
		left: var(--x);
		top: var(--y);
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 0.65rem;
		background: rgba(0, 0, 0, 0.2);
		padding: 0.48rem 0.65rem;
		color: rgba(255, 255, 255, 0.68);
		font-family: "JetBrains Mono Variable", Consolas, monospace;
		font-size: 0.82rem;
		animation: hero-snippet-in 680ms ease both;
		animation-delay: var(--d);
		backdrop-filter: blur(10px);
	}

	@keyframes hero-snippet-in {
		from {
			opacity: 0;
			transform: translateY(0.7rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 640px) {
		.home-hero {
			min-height: 30rem;
		}

		.hero-content {
			padding: 2rem 1.35rem;
		}

		.home-hero h1 {
			max-width: 11ch;
			font-size: 2.7rem;
		}

		.hero-snippets span {
			display: none;
		}
	}

	@media (min-width: 641px) and (max-width: 1024px) {
		.home-hero h1 {
			font-size: 3.35rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-primary,
		.hero-secondary,
		.hero-snippets span {
			animation: none;
			transition: none;
		}

		.hero-primary:hover,
		.hero-secondary:hover {
			transform: none;
		}
	}
</style>
